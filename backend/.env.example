# Database
# Use pooled connection for app runtime (Supabase or local)
DATABASE_URL=postgresql://swiftdrop:swiftdroppass@postgres:5432/swiftdrop

# Direct connection for migrations
DIRECT_URL=postgresql://swiftdrop:swiftdroppass@postgres:5432/swiftdrop

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=replace_this_with_secure_secret
JWT_EXPIRES_IN=1h

# CORS
CORS_ORIGIN=http://localhost:5173

# App
PORT=3001
BCRYPT_SALT_ROUNDS=12
